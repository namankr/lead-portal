# Copy this file to .env and fill in your HubSpot Developer Sandbox values.

# HubSpot Private App access token (Settings -> Integrations -> Private Apps
# in your Developer Sandbox account). Required scopes:
#   crm.objects.contacts.read
#   crm.objects.contacts.write
#   crm.objects.deals.read
#   crm.objects.deals.write
HUBSPOT_ACCESS_TOKEN=

# Optional: internal name of the deal pipeline leads should land in.
# Defaults to "default" (every portal's built-in Sales pipeline).
HUBSPOT_DEAL_PIPELINE=default

# Optional: internal name of the deal stage new leads should be created in.
# Leave blank to let HubSpot use the pipeline's default (first) stage.
HUBSPOT_DEAL_STAGE=

# Port the server listens on.
PORT=3000

SUPABASE_URL=https://<your-ref>.supabase.co
SUPABASE_KEY=<your service_role secret key>